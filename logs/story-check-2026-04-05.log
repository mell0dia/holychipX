  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Press Start 2P', monospace;
      background: #fff;
      color: #000;
      min-height: 100vh;
    }

    #nav-container { position: relative; z-index: 10; }

    /* ── Page wrapper ──────────────────────────────────── */
    .page {
      max-width: 1200px;
      margin: 0 auto;
      padding: 2.5rem 1.5rem;
    }

    .page-header {
      border-bottom: 3px solid #000;
      padding-bottom: 1rem;
      margin-bottom: 2rem;
      display: flex;
      align-items: baseline;
      gap: 1rem;
    }

    .page-header h1 {
      font-size: 1.4rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
    }

    #story-count {
      font-size: 0.75rem;
      color: #888;
      letter-spacing: 0.1em;
    }

    /* ── Loading ─────────────────────────────────────────── */
    #loading {
      font-size: 0.8rem;
      letter-spacing: 0.15em;
      color: #aaa;
      text-transform: uppercase;
      margin-bottom: 1rem;
    }

    /* ── Grid ────────────────────────────────────────────── */
    #grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));
      gap: 1.5rem;
    }

    @media (max-width: 768px) {
      .page { padding: 1.5rem 1rem; }
      #grid { grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 1rem; }
    }

    @media (max-width: 480px) {
      .page { padding: 1rem 0.75rem; }
      .page-header h1 { font-size: 0.98rem; }
      #grid { grid-template-columns: 1fr; gap: 0.75rem; }
      .reader-images img { max-height: 65vh; }
    }

    .story-card {
      position: relative;
      border: 2px solid #000;
      cursor: pointer;
      overflow: hidden;
      aspect-ratio: 3/2;
      background: #111;
      box-shadow: 4px 4px 0 #000;
      transition: transform 0.15s, box-shadow 0.15s;
    }

    .story-card:hover {
      transform: translate(-2px, -2px);
      box-shadow: 6px 6px 0 #000;
    }

    /* Faded background = main story image */
    .card-bg {
      position: absolute;
      inset: 0;
      width: 100%; height: 100%;
      object-fit: cover;
      opacity: 0.07;
      filter: grayscale(100%);
    }

    /* Superposed = pre image, centered */
    .card-pre {
      position: absolute;
      inset: 0;
      width: 100%; height: 100%;
      object-fit: contain;
      filter: grayscale(100%);
      padding: 8px;
    }

    /* Story number label */
    .card-label {
      position: absolute;
      bottom: 0; left: 0; right: 0;
      background: rgba(0,0,0,0.7);
      color: #fff;
      font-size: 0.65rem;
      letter-spacing: 0.2em;
      text-align: center;
      padding: 4px;
      text-transform: uppercase;
    }

    /* Empty state */
    #empty {
      color: #aaa;
      font-size: 0.85rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
    }

    /* ── Card share button ───────────────────────────────── */
    .card-share {
      position: absolute;
      top: 6px;
      right: 6px;
      background: rgba(0,0,0,0.72);
      border: 1px solid rgba(255,255,255,0.3);
      color: #fff;
      width: 30px;
      height: 30px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      opacity: 0;
      transition: opacity 0.2s, background 0.2s;
      z-index: 2;
    }
    .story-card:hover .card-share { opacity: 1; }
    @media (max-width: 768px) { .card-share { opacity: 1; } }
    .card-share:hover { background: rgba(0,0,0,0.95); }

    /* ── Card tweet button ───────────────────────────────── */
    .card-tweet {
      position: absolute;
      top: 42px;
      right: 6px;
      background: rgba(0,0,0,0.72);
      border: 1px solid rgba(255,255,255,0.3);
      color: #fff;
      width: 30px;
      height: 30px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      opacity: 0;
      transition: opacity 0.2s, background 0.2s;
      z-index: 2;
    }
    .story-card:hover .card-tweet { opacity: 1; }
    @media (max-width: 768px) { .card-tweet { opacity: 1; } }
    .card-tweet:hover { background: #000; }

    /* ── Reader / Lightbox ───────────────────────────────── */
    #reader {
      position: fixed;
      inset: 0;
      z-index: 100;
      background: rgba(0,0,0,0.92);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 1rem;
    }

    #reader.hidden { display: none; }

    .reader-inner {
      position: relative;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1rem;
      height: 95vh;
      width: 100%;
      max-width: 1000px;
    }

    .reader-images {
      width: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      flex: 1;
      overflow: hidden;
    }

    .reader-images img {
      max-width: 100%;
      max-height: 78vh;
      width: auto;
      height: auto;
      display: block;
      border: 2px solid #444;
      object-fit: contain;
    }

    #btn-close {
      position: absolute;
      top: -0.5rem;
      right: 0;
      background: transparent;
      color: #fff;
      border: none;
      font-size: 2rem;
      cursor: pointer;
      line-height: 1;
      padding: 0.2rem 0.5rem;
      opacity: 0.7;
      transition: opacity 0.2s;
    }

    #btn-close:hover { opacity: 1; }

    /* ── Reader prev / next ──────────────────────────────── */
    .reader-nav-row { display: contents; } /* desktop: let buttons be absolute */

    .reader-nav {
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      background: rgba(255,255,255,0.08);
      border: 1px solid rgba(255,255,255,0.2);
      color: #fff;
      font-size: 1.6rem;
      line-height: 1;
      width: 48px;
      height: 72px;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      transition: background 0.2s, opacity 0.2s;
      opacity: 0.5;
      z-index: 10;
      user-select: none;
    }
    .reader-nav:hover { background: rgba(255,255,255,0.22); opacity: 1; }
    .reader-nav.hidden { opacity: 0; pointer-events: none; }
    #btn-prev { left: -60px; }
    #btn-next { right: -60px; }

    @media (max-width: 900px) {
      .reader-nav-row {
        display: flex;
        gap: 1rem;
        justify-content: center;
        width: 100%;
        margin-top: 0.5rem;
      }
      .reader-nav {
        position: static;
        transform: none;
        width: 56px;
        height: 56px;
        font-size: 1.4rem;
        opacity: 0.8;
        flex-shrink: 0;
      }
      .reader-nav.hidden { display: none; }
    }

    /* ── Reader footer (label + share) ──────────────────── */
    .reader-footer {
      display: flex;
      align-items: center;
      justify-content: space-between;
      width: 100%;
      padding: 0 0.25rem;
    }

    #btn-share-reader {
      display: flex;
      align-items: center;
      gap: 0.35rem;
      background: rgba(255,255,255,0.08);
      border: 1px solid rgba(255,255,255,0.25);
      color: #ccc;
      font-size: 0.72rem;
      font-family: 'Press Start 2P', monospace;
      letter-spacing: 0.08em;
      cursor: pointer;
      padding: 0.3rem 0.8rem;
      border-radius: 3px;
      transition: background 0.2s, color 0.2s;
    }
    #btn-share-reader:hover { background: rgba(255,255,255,0.18); color: #fff; }

    #btn-tweet-reader {
      display: flex;
      align-items: center;
      gap: 0.35rem;
      background: rgba(255,255,255,0.08);
      border: 1px solid rgba(255,255,255,0.25);
      color: #ccc;
      font-size: 0.72rem;
      font-family: 'Press Start 2P', monospace;
      letter-spacing: 0.08em;
      cursor: pointer;
      padding: 0.3rem 0.8rem;
      border-radius: 3px;
      transition: background 0.2s, color 0.2s;
    }
    #btn-tweet-reader:hover { background: rgba(255,255,255,0.18); color: #fff; }

    .reader-footer-right {
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
  </style>
</head>
<body>

  <div id="nav-container"></div>

  <div class="page">
    <div class="page-header">
      <h1>Stories</h1>
      <span id="story-count"></span>
    </div>

    <div id="loading">Scanning stories...</div>
    <div id="empty" style="display:none">No stories found yet.</div>
    <div id="grid"></div>
  </div>

  <!-- Reader -->
  <div id="reader" class="hidden">
    <div class="reader-inner">
      <button id="btn-close">✕</button>
      <div class="reader-images">
        <img id="reader-story" src="" alt="Story"/>
      </div>
      <div class="reader-nav-row">
        <button id="btn-prev" class="reader-nav">&#8592;</button>
        <button id="btn-next" class="reader-nav">&#8594;</button>
      </div>
      <div class="reader-footer">
        <div style="color:#555;font-size:0.7rem;letter-spacing:0.15em;text-transform:uppercase;" id="reader-label"></div>
        <div class="reader-footer-right">
          <button id="btn-tweet-reader">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            Post
          </button>
          <button id="btn-share-reader">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/></svg>
            Share
          </button>
        </div>
      </div>
    </div>
  </div>

  <script src="assets/nav.js"></script>

  <script>
    const BASE = 'stories/';
    const PAD  = n => String(n).padStart(3, '0');
    let STORIES = [];
    let currentIdx = 0;

    // ── Share utility ────────────────────────────────────────
    function showToast(msg) {
      let toast = document.getElementById('hc-toast');
      if (!toast) {
        toast = document.createElement('div');
        toast.id = 'hc-toast';
        toast.className = 'hc-toast';
        document.body.appendChild(toast);
      }
      toast.textContent = msg;
      toast.classList.add('show');
      clearTimeout(toast._timer);
      toast._timer = setTimeout(() => toast.classList.remove('show'), 2200);
    }

    function shareURL(url, title) {
      if (navigator.share) {
        navigator.share({ url, title }).catch(() => {});
      } else {
        navigator.clipboard.writeText(url).then(() => showToast('Link copied!')).catch(() => showToast('Copy: ' + url));
      }
    }

    function storyURL(num) {
      return window.location.origin + window.location.pathname + '?story=HC' + PAD(num);
    }

    // ── Share icon SVG ───────────────────────────────────────
    const SHARE_SVG = `<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/></svg>`;
    const X_SVG = `<svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>`;

    function tweetStory(num) {
      const url = storyURL(num);
      const text = `Check out this Holy Chip story! HC${PAD(num)}`;
      const tweetURL = `https://twitter.com/intent/tweet?text=${encodeURIComponent(text)}&url=${encodeURIComponent(url)}&via=_holychip`;
      window.open(tweetURL, '_blank', 'noopener,noreferrer,width=550,height=420');
    }

    function buildGrid() {
      const grid = document.getElementById('grid');
      grid.innerHTML = '';
      STORIES.forEach((story, idx) => {
        const card = document.createElement('div');
        card.className = 'story-card';
        card.innerHTML = `
          <img class="card-bg"  src="${story.main}" alt=""/>
          ${story.pre ? `<img class="card-pre" src="${story.pre}" alt=""/>` : ''}
          <div class="card-label">HC${PAD(story.num)}</div>
          <button class="card-share" title="Share this story">${SHARE_SVG}</button>
          <button class="card-tweet" title="Post on X">${X_SVG}</button>
        `;
        card.addEventListener('click', () => openReader(idx));
        card.querySelector('.card-share').addEventListener('click', e => {
          e.stopPropagation();
          shareURL(storyURL(story.num), 'Holy Chip — HC' + PAD(story.num));
        });
        card.querySelector('.card-tweet').addEventListener('click', e => {
          e.stopPropagation();
          tweetStory(story.num);
        });
        grid.appendChild(card);
      });
    }

    // ── Auto-discover HC000 … HC200 (batched to avoid rate-limits) ──
    async function discover() {
      const found = [];
      const BATCH = 20;
      for (let start = 0; start <= 200; start += BATCH) {
        const checks = [];
        for (let n = start; n < Math.min(start + BATCH, 201); n++) {
          const main = `${BASE}HC${PAD(n)}.png`;
          const pre  = `${BASE}HC${PAD(n)}.pre.png`;
          checks.push(
            Promise.all([
              fetch(main, { method: 'HEAD' }).then(r => r.ok ? main : null).catch(() => null),
              fetch(pre,  { method: 'HEAD' }).then(r => r.ok ? pre  : null).catch(() => null),
            ]).then(([m, p]) => m ? { num: n, main: m, pre: p } : null)
          );
        }
        const results = await Promise.all(checks);
        results.forEach(r => { if (r) found.push(r); });
      }
      found.sort((a, b) => a.num - b.num);
      return found;
    }

    // ── Boot ────────────────────────────────────────────────
    discover().then(stories => {
      STORIES = stories;
      document.getElementById('loading').style.display = 'none';
      document.getElementById('story-count').textContent =
        STORIES.length + ' stor' + (STORIES.length === 1 ? 'y' : 'ies');
      if (STORIES.length === 0) {
        document.getElementById('empty').style.display = '';
      } else {
        buildGrid();
        // Deep link: ?story=HC005 auto-opens that story
        const param = new URLSearchParams(window.location.search).get('story');
        if (param) {
          const num = parseInt(param.replace('HC', ''), 10);
          const idx = STORIES.findIndex(s => s.num === num);
          if (idx !== -1) openReader(idx);
        }
      }
    });

    // ── Reader ──────────────────────────────────────────────
    function openReader(idx) {
      currentIdx = idx;
      renderReader();
      document.getElementById('reader').classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    }

    function closeReader() {
      document.getElementById('reader').classList.add('hidden');
      document.body.style.overflow = '';
      history.replaceState(null, '', window.location.pathname);
    }

    function renderReader() {
      const story = STORIES[currentIdx];
      document.getElementById('reader-story').src = story.main;
      document.getElementById('reader-label').textContent = `HC${PAD(story.num)} — ${currentIdx + 1} / ${STORIES.length}`;
      document.getElementById('btn-prev').classList.toggle('hidden', currentIdx === 0);
      document.getElementById('btn-next').classList.toggle('hidden', currentIdx === STORIES.length - 1);
      history.replaceState(null, '', '?story=HC' + PAD(story.num));
    }

    function navigateReader(dir) {
      const next = currentIdx + dir;
      if (next < 0 || next >= STORIES.length) return;
      currentIdx = next;
      renderReader();
    }

    document.getElementById('btn-close').addEventListener('click', e => { e.stopPropagation(); closeReader(); });
    document.getElementById('btn-prev').addEventListener('click', e => { e.stopPropagation(); navigateReader(-1); });
    document.getElementById('btn-next').addEventListener('click', e => { e.stopPropagation(); navigateReader(1); });
    document.getElementById('btn-share-reader').addEventListener('click', e => {
      e.stopPropagation();
      const story = STORIES[currentIdx];
      shareURL(storyURL(story.num), 'Holy Chip — HC' + PAD(story.num));
    });
    document.getElementById('btn-tweet-reader').addEventListener('click', e => {
      e.stopPropagation();
      tweetStory(STORIES[currentIdx].num);
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeReader();
      if (e.key === 'ArrowLeft')  navigateReader(-1);
      if (e.key === 'ArrowRight') navigateReader(1);
    });

    // ── Touch: swipe to navigate, tap background to close ────
    let touchStartX = 0;
    let touchStartTarget = null;
    document.getElementById('reader').addEventListener('touchstart', e => {
      touchStartX = e.touches[0].clientX;
      touchStartTarget = e.target;
    }, { passive: true });
    document.getElementById('reader').addEventListener('touchend', e => {
      // If the touch started on any button, do nothing — let the click event handle it
      if (touchStartTarget && touchStartTarget.closest('button')) return;
      const dx = e.changedTouches[0].clientX - touchStartX;
      if (Math.abs(dx) > 50) { navigateReader(dx < 0 ? 1 : -1); }
      else closeReader();
    }, { passive: true });
  </script>
</body>
</html>

